DATABASE_URL="postgresql://hrownik:hrownik@localhost:5432/hrownik"
BETTER_AUTH_SECRET="change-me-use-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Solvro Auth (self-hosted Keycloak) — leave unset to disable OIDC login.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# USOS login (better-auth-usos) — leave unset to disable USOS login.
USOS_BASE_URL=
USOS_CONSUMER_KEY=
USOS_CONSUMER_SECRET=
USOS_EMAIL_DOMAIN=

# GitHub org integration — used starting Phase 1/2 automations.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_ORG=
# Set the same value as the GitHub App's "Webhook secret".
GITHUB_WEBHOOK_SECRET=

# Discord automation — used starting Phase 1.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INVITE_CHANNEL_ID=
